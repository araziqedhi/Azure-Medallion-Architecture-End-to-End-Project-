{
	"name": "RawToEnr",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "github_sink",
						"type": "DatasetReference"
					},
					"name": "rawsource"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "extDataLake",
						"type": "LinkedServiceReference"
					},
					"name": "sinkEnr"
				}
			],
			"transformations": [
				{
					"name": "removeNulls"
				},
				{
					"name": "columndrop"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Item_Identifier as string,",
				"          Item_Weight as string,",
				"          Item_Fat_Content as string,",
				"          Item_Visibility as string,",
				"          Item_Type as string,",
				"          Item_MRP as string,",
				"          Outlet_Identifier as string,",
				"          Outlet_Establishment_Year as string,",
				"          Outlet_Size as string,",
				"          Outlet_Location_Type as string,",
				"          Outlet_Type as string,",
				"          Item_Outlet_Sales as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> rawsource",
				"rawsource derive(Outlet_Size = iif(isNull(Outlet_Size),'N/A',Outlet_Size),",
				"          Item_MRP = toInteger(Item_MRP),",
				"          Item_Weight = toFloat(Item_Weight),",
				"          Item_Outlet_Sales = toFloat(Item_Outlet_Sales)) ~> removeNulls",
				"removeNulls select(mapColumn(",
				"          Item_Identifier,",
				"          Item_Weight,",
				"          Item_Fat_Content,",
				"          Item_Type,",
				"          Item_MRP,",
				"          Outlet_Identifier,",
				"          Outlet_Establishment_Year,",
				"          Outlet_Size,",
				"          Outlet_Location_Type,",
				"          Outlet_Type,",
				"          Item_Outlet_Sales",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> columndrop",
				"columndrop sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'enriched',",
				"     folderPath: 'github/data',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: false,",
				"     upsertable: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkEnr"
			]
		}
	}
}